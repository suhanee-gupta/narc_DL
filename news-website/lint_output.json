п»ҝ[{"filePath":"E:\\news\\eslint.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\news\\postcss.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\news\\src\\App.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\news\\src\\NewsroomApp.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'getRankedNews' is defined but never used. Allowed unused vars must match /^[A-Z_]/u.","line":10,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":23,"suggestions":[{"messageId":"removeVar","data":{"varName":"getRankedNews"},"fix":{"range":[329,343],"text":""},"desc":"Remove unused variable 'getRankedNews'."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from \"react\";\nconst { useState: mUS, useEffect: mUE, useMemo: mUM } = React;\n\nimport PersonalizationDrawer from \"./PersonalizationDrawer.jsx\";\nimport {\n  NewsTopBar, NewsMasthead, NewsNav,\n  NewsHero, NewsSection, NewsCard, NewsPodcastCard, NewsFooter,\n  NewsImg, MatchChip\n} from \"./newsroom-content.jsx\";\nimport { getRankedNews, PROFILES, CORPUS, scoreArticle } from \"./engine.jsx\";\n\nconst N_TOPICS = [\n  {\n    label: \"World\", tagline: \"Dispatches from 48 bureaus\",\n    icon: <svg width=\"18\" height=\"18\" viewBox=\"0 0 22 22\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.2\">\n      <circle cx=\"11\" cy=\"11\" r=\"9\" /><ellipse cx=\"11\" cy=\"11\" rx=\"4\" ry=\"9\" /><path d=\"M2 11 L20 11\" /></svg>\n  },\n  {\n    label: \"Technology\", tagline: \"Circuits, code, consequence\",\n    icon: <svg width=\"18\" height=\"18\" viewBox=\"0 0 22 22\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.2\">\n      <rect x=\"4\" y=\"4\" width=\"14\" height=\"14\" /><rect x=\"8\" y=\"8\" width=\"6\" height=\"6\" /></svg>\n  },\n  {\n    label: \"Health\", tagline: \"Bodies, systems, policies\",\n    icon: <svg width=\"18\" height=\"18\" viewBox=\"0 0 22 22\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.2\">\n      <path d=\"M11 4 L11 18 M4 11 L18 11\" /></svg>\n  },\n  {\n    label: \"Finance\", tagline: \"Markets and the money map\",\n    icon: <svg width=\"18\" height=\"18\" viewBox=\"0 0 22 22\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.2\">\n      <path d=\"M3 18 L8 12 L12 15 L19 6\" /><path d=\"M14 6 L19 6 L19 11\" /></svg>\n  },\n];\n\nexport function NewsTopicStrip({ topics, active, onPick }) {\n  return (\n    <div style={{ display: 'flex', gap: 12, overflowX: 'auto', paddingBottom: 16 }}>\n      {topics.map(t => (\n        <button key={t.label} onClick={() => onPick(t.label)} style={{\n          display: 'flex', gap: 12, alignItems: 'center', padding: \"12px 18px\",\n          border: active === t.label ? \"1px solid var(--ink)\" : \"1px solid rgba(0,0,0,0.12)\",\n          background: active === t.label ? \"var(--ink)\" : \"var(--bone)\",\n          color: active === t.label ? \"var(--bone)\" : \"var(--ink)\",\n          cursor: \"pointer\", whiteSpace: \"nowrap\", textAlign: \"left\", flexShrink: 0\n        }}>\n          {t.icon}\n          <div>\n            <div style={{ fontFamily: \"'Inter', sans-serif\", fontSize: 13, fontWeight: 700, letterSpacing: \"0.05em\" }}>{t.label}</div>\n            <div style={{ fontFamily: \"'Inter', sans-serif\", fontSize: 10, opacity: 0.7, marginTop: 2 }}>{t.tagline}</div>\n          </div>\n        </button>\n      ))}\n    </div>\n  );\n}\n\nexport default function NewsroomApp() {\n  const BRAND = \"The Margin\";\n  const [ctx, setCtx] = mUS({ profile: \"analyst\", mood: 0.3, timeContext: \"morning\", env: \"\" });\n  const [drawerOpen, setDrawerOpen] = mUS(false);\n  const [activeCat, setActiveCat] = mUS(\"Home\");\n  const [playing, setPlaying] = mUS(null);\n  const [reranking, setReranking] = mUS(false);\n\n  const ranked = mUM(() => {\n    const scored = CORPUS.map(a => {\n      const { score, reasons } = scoreArticle(a, ctx);\n      return { ...a, score, reasons };\n    });\n    scored.sort((a, b) => b.score - a.score);\n    return scored;\n  }, [ctx]);\n\n  const confidence = mUM(() => {\n    if (ctx.profile === \"newuser\") return 0.35;\n    const top = ranked.slice(0, 8);\n    return top.reduce((s, a) => s + a.score, 0) / top.length;\n  }, [ranked, ctx.profile]);\n\n  mUE(() => {\n    setReranking(true);\n    const t = setTimeout(() => setReranking(false), 500);\n    return () => clearTimeout(t);\n  }, [ctx]);\n\n  const cssVars = {\n    \"--bone\": \"#FFFFFF\",\n    \"--ink\": \"#111111\",\n    \"--accent\": \"#C21E3B\",\n  };\n\n  // Slice the ranked corpus into the editorial sections\n  const hero = ranked[0];\n  const latestLarge = ranked[1];\n  const latestSide = ranked.slice(2, 4);\n  const latestRow = ranked.slice(4, 7);\n  const worldMain = ranked.find(a => a.topic === \"Geopolitics\") || ranked[7];\n  const worldSecondary = ranked.filter(a => a.id !== worldMain.id).slice(0, 3);\n  const techRow = ranked.filter(a => a.topic === \"Tech\").slice(0, 4);\n  const podcastRow = ranked.filter(a => a.length === \"deep\" || a.tone === \"relaxed\").slice(0, 6);\n\n  return (\n    <div style={{\n      ...cssVars, background: \"var(--bone)\", minHeight: \"100vh\",\n      fontFamily: \"'Inter', sans-serif\", color: \"var(--ink)\"\n    }}>\n      <div style={{ maxWidth: 1240, margin: \"0 auto\", padding: \"0 48px\" }}>\n        <NewsTopBar\n          onOpenFilter={() => setDrawerOpen(true)}\n          onOpenSearch={() => { }}\n          onToggleMenu={() => { }}\n        />\n        <NewsMasthead brand={BRAND} />\n        <NewsNav active={activeCat} onChange={setActiveCat}\n          categories={[\"Home\", \"World\", \"Politics\", \"Business\", \"Technology\", \"Health\", \"Sports\", \"Culture\", \"Podcast\"]} />\n        <NewsTopicStrip topics={N_TOPICS} active={activeCat} onPick={setActiveCat} />\n\n        {/* Re-rank status line */}\n        <div style={{\n          marginTop: 8, padding: \"10px 14px\",\n          border: \"1px solid rgba(0,0,0,0.12)\",\n          display: \"flex\", justifyContent: \"space-between\", alignItems: \"center\", gap: 16,\n          fontFamily: \"'Inter', sans-serif\", fontSize: 11,\n          letterSpacing: \"0.12em\", textTransform: \"uppercase\", color: \"var(--ink)\",\n        }}>\n          <div style={{ display: \"flex\", gap: 14, alignItems: \"center\", minWidth: 0, flexWrap: \"wrap\" }}>\n            <span style={{\n              width: 7, height: 7, borderRadius: \"50%\", flexShrink: 0,\n              background: reranking ? \"var(--accent)\" : \"#1E7A3A\",\n              animation: reranking ? \"blink 0.6s ease-in-out infinite alternate\" : \"none\",\n            }} />\n            <span style={{ fontWeight: 600 }}>\n              {reranking ? \"Re-ranking feedО“ГҮВӘ\" : `Feed tuned for ${PROFILES[ctx.profile].name}`}\n            </span>\n            <span style={{ opacity: 0.45 }}>в”¬в•–</span>\n            <span style={{ opacity: 0.7 }}>{Math.round(confidence * 100)}% match</span>\n            <span style={{ opacity: 0.45 }}>в”¬в•–</span>\n            <span style={{ opacity: 0.7 }}>\n              {ctx.timeContext === \"morning\" ? \"Morning rush\" :\n                ctx.timeContext === \"deepwork\" ? \"Deep work\" : \"Wind-down\"}\n            </span>\n          </div>\n          <button onClick={() => setDrawerOpen(true)} style={{\n            flexShrink: 0, background: \"transparent\", border: \"1px solid var(--ink)\",\n            padding: \"5px 12px\", cursor: \"pointer\", whiteSpace: \"nowrap\",\n            fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 600,\n            letterSpacing: \"0.18em\", color: \"var(--ink)\",\n          }}>Personalize О“ГҘГҶ</button>\n        </div>\n\n        {/* Hero */}\n        <NewsHero a={hero} match={Math.round(hero.score * 100)} />\n\n        {/* Latest */}\n        <NewsSection label=\"Latest News\">\n          <div style={{\n            display: \"grid\", gridTemplateColumns: \"1.15fr 1fr\", gap: 40,\n            animation: reranking ? \"fadeIn 500ms ease\" : \"none\",\n          }}>\n            <NewsCard a={latestLarge} variant=\"large\" match={Math.round(latestLarge.score * 100)} />\n            <div style={{ display: \"flex\", flexDirection: \"column\" }}>\n              {latestSide.map(a => (\n                <NewsCard key={a.id} a={a} variant=\"row\" match={Math.round(a.score * 100)} />\n              ))}\n            </div>\n          </div>\n          <div style={{\n            display: \"grid\", gridTemplateColumns: \"repeat(3, 1fr)\", gap: 30,\n            marginTop: 34, paddingTop: 30, borderTop: \"1px solid rgba(0,0,0,0.1)\",\n            animation: reranking ? \"fadeIn 500ms ease\" : \"none\",\n          }}>\n            {latestRow.map(a => (\n              <NewsCard key={a.id} a={a} variant=\"compact\" match={Math.round(a.score * 100)} />\n            ))}\n          </div>\n        </NewsSection>\n\n        {/* World */}\n        <NewsSection label=\"World News\">\n          <div style={{\n            display: \"grid\", gridTemplateColumns: \"1.4fr 1fr\", gap: 36,\n            animation: reranking ? \"fadeIn 500ms ease\" : \"none\",\n          }}>\n            <article style={{ position: \"relative\", cursor: \"pointer\" }}>\n              <NewsImg a={worldMain} ratio=\"5 / 4\" />\n              <div style={{\n                position: \"absolute\", left: 20, top: 20,\n                padding: \"8px 14px\", background: \"var(--bone)\", border: \"1px solid var(--ink)\",\n                fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 600,\n                letterSpacing: \"0.22em\", textTransform: \"uppercase\",\n              }}>World News</div>\n              <div style={{ position: \"absolute\", top: 20, right: 20 }}>\n                <MatchChip pct={Math.round(worldMain.score * 100)} />\n              </div>\n              <div style={{\n                position: \"absolute\", left: 24, bottom: 24,\n                background: \"var(--bone)\", padding: \"18px 22px\", maxWidth: 420,\n                border: \"1px solid var(--ink)\",\n              }}>\n                <h3 style={{\n                  margin: 0, fontFamily: \"'Playfair Display', serif\",\n                  fontSize: 22, fontWeight: 500, lineHeight: 1.25, color: \"var(--ink)\",\n                }}>{worldMain.headline}</h3>\n                <div style={{\n                  marginTop: 10,\n                  fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 500,\n                  letterSpacing: \"0.18em\", color: \"var(--ink)\", opacity: 0.6,\n                  textTransform: \"uppercase\"\n                }}>\n                  By {worldMain.author} в”¬в•– {worldMain.minutes} min\n                </div>\n              </div>\n            </article>\n            <div style={{ display: \"flex\", flexDirection: \"column\" }}>\n              {worldSecondary.map(a => (\n                <NewsCard key={a.id} a={a} variant=\"row\" match={Math.round(a.score * 100)} />\n              ))}\n            </div>\n          </div>\n        </NewsSection>\n\n        {/* Technology */}\n        <NewsSection label=\"Technology News\">\n          <div style={{\n            display: \"grid\", gridTemplateColumns: \"repeat(4, 1fr)\", gap: 24,\n            animation: reranking ? \"fadeIn 500ms ease\" : \"none\",\n          }}>\n            {techRow.map(a => (\n              <NewsCard key={a.id} a={a} variant=\"compact\" match={Math.round(a.score * 100)} />\n            ))}\n          </div>\n        </NewsSection>\n\n        {/* Podcasts */}\n        <NewsSection label=\"Podcasts\">\n          <div style={{\n            display: \"grid\", gridTemplateColumns: \"repeat(3, 1fr)\", gap: 20,\n            animation: reranking ? \"fadeIn 500ms ease\" : \"none\",\n          }}>\n            {podcastRow.map(a => (\n              <NewsPodcastCard key={a.id} a={a}\n                playing={playing}\n                onToggle={(id) => setPlaying(playing === id ? null : id)}\n                match={Math.round(a.score * 100)} />\n            ))}\n          </div>\n        </NewsSection>\n\n        <NewsFooter brand={BRAND} />\n      </div>\n\n      <PersonalizationDrawer\n        open={drawerOpen}\n        onClose={() => setDrawerOpen(false)}\n        context={ctx}\n        onSave={setCtx}\n        confidence={confidence}\n        latency=\"0.4\"\n      />\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"E:\\news\\src\\PersonalizationDrawer.jsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook React.useEffect has a missing dependency: 'setDraft'. Either include it or remove the dependency array.","line":9,"column":59,"nodeType":"ArrayExpression","endLine":9,"endColumn":74,"suggestions":[{"desc":"Update the dependencies array to be: [open, context, setDraft]","fix":{"range":[345,360],"text":"[open, context, setDraft]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport { PROFILES } from './engine.jsx';\n\n// Off-canvas personalization drawer\nconst { useState: dUS } = React;\n\nexport default function PersonalizationDrawer({ open, onClose, context, onSave, confidence, latency }) {\n  const [draft, setDraft] = dUS(context);\n  React.useEffect(() => { if (open) setDraft(context); }, [open, context]);\n\n  return (\n    <>\n      <div onClick={onClose} style={{\n        position: \"fixed\", inset: 0, background: \"rgba(15,15,15,0.35)\",\n        opacity: open ? 1 : 0, pointerEvents: open ? \"auto\" : \"none\",\n        transition: \"opacity 240ms\",\n        zIndex: 40,\n      }}/>\n      <aside style={{\n        position: \"fixed\", top: 0, right: 0, bottom: 0,\n        width: \"min(440px, 92vw)\", background: \"var(--bone)\",\n        borderLeft: \"1px solid var(--ink)\",\n        transform: `translateX(${open ? \"0\" : \"100%\"})`,\n        transition: \"transform 320ms cubic-bezier(.2,.7,.2,1)\",\n        zIndex: 50, display: \"flex\", flexDirection: \"column\",\n        boxShadow: open ? \"-20px 0 40px rgba(0,0,0,0.15)\" : \"none\",\n      }}>\n        <header style={{\n          padding: \"22px 26px\", borderBottom: \"1px solid var(--ink)\",\n          display: \"flex\", justifyItems: \"space-between\", justifyContent: \"space-between\", alignItems: \"flex-start\",\n        }}>\n          <div>\n            <div style={{\n              fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 600,\n              letterSpacing: \"0.22em\", textTransform: \"uppercase\",\n              color: \"var(--ink)\", opacity: 0.55, marginBottom: 6,\n            }}>Personalization</div>\n            <h2 style={{\n              margin: 0, fontFamily: \"'Playfair Display', serif\",\n              fontSize: 28, fontWeight: 500, letterSpacing: \"-0.01em\",\n            }}>Tune your feed</h2>\n          </div>\n          <button onClick={onClose} aria-label=\"Close\" style={{\n            background: \"transparent\", border: \"1px solid var(--ink)\",\n            width: 32, height: 32, cursor: \"pointer\",\n            display: \"flex\", alignItems: \"center\", justifyContent: \"center\",\n            color: \"var(--ink)\",\n          }}>\n            <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.4\">\n              <path d=\"M2 2 L10 10 M10 2 L2 10\"/>\n            </svg>\n          </button>\n        </header>\n\n        <div style={{ flex: 1, overflowY: \"auto\", padding: \"24px 26px\",\n          display: \"flex\", flexDirection: \"column\", gap: 28 }}>\n\n          <DrawerField label=\"User Profile\" note=\"Switch simulated reader. New User triggers cold-start.\">\n            <div style={{ display: \"flex\", flexDirection: \"column\", gap: 8 }}>\n              {Object.entries(PROFILES).map(([id, p]) => (\n                <button key={id} onClick={() => setDraft({ ...draft, profile: id })}\n                  style={{\n                    textAlign: \"left\", padding: \"12px 14px\",\n                    background: draft.profile === id ? \"var(--ink)\" : \"var(--bone)\",\n                    color: draft.profile === id ? \"var(--bone)\" : \"var(--ink)\",\n                    border: \"1px solid var(--ink)\", cursor: \"pointer\",\n                    display: \"flex\", flexDirection: \"column\", gap: 3,\n                    transition: \"all 140ms\",\n                  }}>\n                  <span style={{ fontFamily: \"'Inter', sans-serif\", fontSize: 13, fontWeight: 600 }}>\n                    {p.name}\n                  </span>\n                  <span style={{ fontSize: 11, opacity: 0.75,\n                    fontFamily: \"'Inter', sans-serif\", lineHeight: 1.4 }}>{p.bio}</span>\n                </button>\n              ))}\n            </div>\n          </DrawerField>\n\n          <DrawerField label=\"Mood Meter\" note=\"Drives tone selection.\">\n            <div style={{\n              display: \"flex\", justifyContent: \"space-between\",\n              fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 500,\n              letterSpacing: \"0.18em\", textTransform: \"uppercase\",\n              color: \"var(--ink)\", opacity: 0.55, marginBottom: 8,\n            }}>\n              <span>High Stress</span>\n              <span>Leisure</span>\n            </div>\n            <input type=\"range\" min=\"0\" max=\"100\" value={draft.mood * 100}\n              onChange={e => setDraft({ ...draft, mood: +e.target.value / 100 })}\n              className=\"drawer-range\"\n              style={{ width: \"100%\" }}/>\n            <div style={{\n              textAlign: \"center\", marginTop: 8,\n              fontFamily: \"'Playfair Display', serif\", fontStyle: \"italic\", fontSize: 14,\n              color: \"var(--ink)\", opacity: 0.75,\n            }}>\n              {draft.mood < 0.25 ? \"Focused в”¬в•– headlines only\" :\n               draft.mood < 0.55 ? \"Measured в”¬в•– mixed pace\" :\n               draft.mood < 0.8 ? \"Uplifted в”¬в•– lighter reads\" :\n                                  \"Relaxed в”¬в•– leisure reading\"}\n            </div>\n          </DrawerField>\n\n          <DrawerField label=\"Time Context\">\n            <div style={{ display: \"grid\", gridTemplateColumns: \"repeat(3, 1fr)\", gap: 8 }}>\n              {[[\"morning\",\"Morning\\nRush\"],[\"deepwork\",\"Deep\\nWork\"],[\"evening\",\"Wind-\\ndown\"]].map(([v,l]) => (\n                <button key={v} onClick={() => setDraft({ ...draft, timeContext: v })}\n                  style={{\n                    padding: \"14px 8px\", whiteSpace: \"pre-line\",\n                    background: draft.timeContext === v ? \"var(--ink)\" : \"var(--bone)\",\n                    color: draft.timeContext === v ? \"var(--bone)\" : \"var(--ink)\",\n                    border: \"1px solid var(--ink)\", cursor: \"pointer\",\n                    fontFamily: \"'Inter', sans-serif\", fontSize: 12, fontWeight: 500,\n                    lineHeight: 1.3,\n                  }}>{l}</button>\n              ))}\n            </div>\n          </DrawerField>\n\n          <DrawerField label=\"Environmental Signal\"\n            note=\"Try: gym, commute, desk, home, market.\">\n            <input value={draft.env || ''} onChange={e => setDraft({ ...draft, env: e.target.value })}\n              placeholder=\"e.g. at the gym, on the trainО“ГҮВӘ\"\n              style={{\n                width: \"100%\", padding: \"12px 14px\",\n                background: \"transparent\", border: \"1px solid var(--ink)\",\n                color: \"var(--ink)\", fontSize: 13,\n                fontFamily: \"'Inter', sans-serif\", outline: \"none\",\n              }}/>\n          </DrawerField>\n        </div>\n\n        <footer style={{\n          padding: \"18px 26px\", borderTop: \"1px solid var(--ink)\",\n          display: \"flex\", flexDirection: \"column\", gap: 14,\n        }}>\n          <div style={{\n            fontFamily: \"'Inter', sans-serif\", fontSize: 11, fontWeight: 500,\n            letterSpacing: \"0.1em\", textTransform: \"uppercase\",\n            color: \"var(--ink)\", opacity: 0.6, textAlign: \"center\",\n          }}>\n            Generated in {latency}s в”¬в•– {Math.round(confidence * 100)}% confidence\n          </div>\n          <button onClick={() => { onSave(draft); onClose(); }}\n            style={{\n              padding: \"14px 18px\", background: \"var(--ink)\", color: \"var(--bone)\",\n              border: \"1px solid var(--ink)\", cursor: \"pointer\",\n              fontFamily: \"'Inter', sans-serif\", fontSize: 12, fontWeight: 600,\n              letterSpacing: \"0.22em\", textTransform: \"uppercase\",\n              transition: \"background 140ms, color 140ms\",\n            }}\n            onMouseEnter={e => { e.currentTarget.style.background = \"var(--accent)\"; }}\n            onMouseLeave={e => { e.currentTarget.style.background = \"var(--ink)\"; }}\n          >\n            Save & Update Feed\n          </button>\n        </footer>\n      </aside>\n    </>\n  );\n}\n\nfunction DrawerField({ label, note, children }) {\n  return (\n    <div>\n      <div style={{\n        fontFamily: \"'Inter', sans-serif\", fontSize: 11, fontWeight: 600,\n        letterSpacing: \"0.22em\", textTransform: \"uppercase\",\n        color: \"var(--ink)\", marginBottom: 6,\n      }}>{label}</div>\n      {note && <div style={{\n        fontFamily: \"'Inter', sans-serif\", fontSize: 11, color: \"var(--ink)\",\n        opacity: 0.6, marginBottom: 12, lineHeight: 1.5,\n      }}>{note}</div>}\n      {children}\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"E:\\news\\src\\engine.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\news\\src\\main.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\news\\src\\newsroom-content.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'sUE' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":2,"column":35,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":38,"suggestions":[{"messageId":"removeVar","data":{"varName":"sUE"},"fix":{"range":[73,89],"text":""},"desc":"Remove unused variable 'sUE'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'sUR' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":2,"column":48,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":51,"suggestions":[{"messageId":"removeVar","data":{"varName":"sUR"},"fix":{"range":[89,102],"text":""},"desc":"Remove unused variable 'sUR'."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\nconst { useState: sUS, useEffect: sUE, useRef: sUR } = React;\nimport { Search, Menu, Play } from 'lucide-react';\n\n// О“Г¶ГҮО“Г¶ГҮ Image placeholder О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsImg({ a, ratio = \"16 / 10\" }) {\n  const palettes = {\n    Finance:    { bg: \"#2B2A28\", fg: \"#9A9188\", accent: \"#E8D9B8\" },\n    Tech:       { bg: \"#1C2028\", fg: \"#6E7684\", accent: \"#C8D0DC\" },\n    Lifestyle:  { bg: \"#2A2823\", fg: \"#8A8074\", accent: \"#D8CFBD\" },\n    Geopolitics:{ bg: \"#26201C\", fg: \"#8A786A\", accent: \"#D9C4AE\" },\n    Health:     { bg: \"#222528\", fg: \"#7F8A94\", accent: \"#CAD5DE\" },\n    Culture:    { bg: \"#261F24\", fg: \"#857580\", accent: \"#D6C6CF\" },\n  };\n  const p = palettes[a?.topic] || palettes.Tech;\n\n  return (\n    <div className=\"relative w-full overflow-hidden\" style={{ aspectRatio: ratio, background: p.bg }}>\n      <svg className=\"absolute inset-0 w-full h-full\">\n        <defs>\n          <linearGradient id={`ng${a?.id || \"0\"}`} x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stopColor={p.fg} stopOpacity=\"0.55\"/>\n            <stop offset=\"100%\" stopColor={p.bg} stopOpacity=\"1\"/>\n          </linearGradient>\n          <pattern id={`grain${a?.id || \"0\"}`} width=\"3\" height=\"3\" patternUnits=\"userSpaceOnUse\">\n            <rect width=\"3\" height=\"3\" fill={p.fg} opacity=\"0.04\"/>\n            <circle cx=\"1\" cy=\"1\" r=\"0.3\" fill={p.accent} opacity=\"0.12\"/>\n          </pattern>\n        </defs>\n        <rect width=\"100%\" height=\"100%\" fill={`url(#ng${a?.id || \"0\"})`}/>\n        <rect width=\"100%\" height=\"100%\" fill={`url(#grain${a?.id || \"0\"})`}/>\n      </svg>\n      <div className=\"absolute inset-0 flex items-center justify-center font-mono text-[10px] tracking-[0.25em] uppercase text-center p-[18px]\" style={{ color: p.accent, opacity: 0.7 }}>\n        [ {a?.topic || \"News\"} в”¬в•– #{String(a?.id || \"0\").padStart(3,\"0\")} ]\n      </div>\n    </div>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Match chip О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function MatchChip({ pct, compact }) {\n  return (\n    <span className={`inline-flex items-center gap-1.5 border border-neutral-900 bg-white font-mono font-medium text-neutral-900 tracking-[0.15em] ${compact ? 'px-[7px] py-[2px] text-[9px]' : 'px-[9px] py-[3px] text-[10px]'}`}>\n      <span className=\"w-[5px] h-[5px] rounded-full\" style={{ background: pct > 85 ? \"#1E7A3A\" : pct > 65 ? \"#B8860B\" : \"#888\" }} />\n      {pct}% MATCH\n    </span>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Live clock О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsClock() {\n  const [now, setNow] = useState(new Date());\n  useEffect(() => { \n    const t = setInterval(() => setNow(new Date()), 30000); \n    return () => clearInterval(t); \n  }, []);\n  \n  const days = [\"Sunday\",\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\",\"Saturday\"];\n  const months = [\"January\",\"February\",\"March\",\"April\",\"May\",\"June\",\"July\",\"August\",\"September\",\"October\",\"November\",\"December\"];\n  \n  return (\n    <span className=\"font-sans text-xs font-medium text-neutral-900\">\n      {days[now.getDay()]}, {months[now.getMonth()]} {now.getDate()}, {now.getFullYear()}\n    </span>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Masthead О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsMasthead({ brand }) {\n  return (\n    <div className=\"text-center pt-7 pb-3.5\">\n      <h1 className=\"font-serif text-[72px] leading-[0.95] m-0 tracking-[-0.02em] text-neutral-900 font-medium italic\">\n        {brand}\n        <span className=\"not-italic ml-0.5 text-[#C21E3B]\">*</span>\n      </h1>\n    </div>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Top bar О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsTopBar({ onOpenFilter, onOpenSearch, onToggleMenu }) {\n  return (\n    <div className=\"flex justify-between items-center py-5\">\n      <NewsClock />\n      <div className=\"flex gap-4 items-center\">\n        <button onClick={onToggleMenu} className=\"bg-transparent border-none cursor-pointer font-sans text-xs font-medium text-neutral-900 p-0 hover:underline\">\n          The Menu\n        </button>\n        <span className=\"text-neutral-900/20\">|</span>\n        <button onClick={onOpenSearch} className=\"bg-transparent border border-neutral-900 p-1.5 cursor-pointer text-neutral-900 inline-flex items-center justify-center hover:bg-neutral-100 transition-colors\">\n          <Search size={14} className=\"stroke-[1.5]\" />\n        </button>\n        <button onClick={onOpenFilter} title=\"Personalize feed\" className=\"bg-transparent border border-neutral-900 p-1.5 cursor-pointer text-[#C21E3B] border-[#C21E3B] inline-flex items-center gap-1.5 justify-center hover:bg-[#C21E3B] hover:text-white transition-colors\">\n          <Menu size={14} className=\"stroke-[2]\" /> \n          <span className=\"font-sans text-[10px] font-bold tracking-[0.2em] uppercase pr-1\">Personalize</span>\n        </button>\n      </div>\n    </div>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Nav О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsNav() {\n  const categories = [\"Home\", \"World\", \"Politics\", \"Business\", \"Technology\", \"Health\", \"Sports\", \"Culture\", \"Podcast\"];\n  return (\n    <nav className=\"flex justify-center py-3 border-y border-neutral-900 mb-10\">\n      {categories.map((c, i) => (\n        <button \n          key={c} \n          className={`relative bg-transparent border-none cursor-pointer px-[22px] py-1 font-sans text-xs font-semibold text-neutral-900 ${\n            c === \"Home\" ? 'opacity-100' : 'opacity-70 hover:opacity-100'\n          } ${i < categories.length - 1 ? 'border-r border-neutral-900/10' : ''}`}\n        >\n          {c}\n          {c === \"Home\" && (\n            <span className=\"absolute left-1/2 -bottom-[13px] -translate-x-1/2 w-1 h-1 rounded-full bg-[#C21E3B]\" />\n          )}\n        </button>\n      ))}\n    </nav>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Hero top story (bound to top-ranked article) О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsHero({ a, match }) {\n  const [hov, setHov] = sUS(false);\n  return (\n    <article onMouseEnter={() => setHov(true)} onMouseLeave={() => setHov(false)}\n      style={{ margin: \"28px 0 18px\", cursor: \"pointer\" }}>\n      <div style={{ position: \"relative\", overflow: \"hidden\" }}>\n        <div style={{\n          transform: hov ? \"scale(1.015)\" : \"scale(1)\",\n          transition: \"transform 500ms cubic-bezier(.2,.7,.2,1)\",\n        }}>\n          <NewsImg a={a} ratio=\"16 / 7.5\"/>\n        </div>\n        <div style={{\n          position: \"absolute\", top: 0, left: 0,\n          background: \"var(--bone)\", padding: \"7px 12px\",\n          border: \"1px solid var(--ink)\", borderTop: \"none\", borderLeft: \"none\",\n          fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 600,\n          letterSpacing: \"0.22em\", textTransform: \"uppercase\", color: \"var(--ink)\",\n        }}>Top Story в”¬в•– #{String(a?.id).padStart(3,\"0\")}</div>\n        <div style={{\n          position: \"absolute\", top: 14, right: 14,\n        }}>\n          <MatchChip pct={match}/>\n        </div>\n      </div>\n      <div style={{ marginTop: 18, display: \"flex\", gap: 10, alignItems: \"center\" }}>\n        <span style={{\n          border: \"1px solid var(--ink)\", padding: \"3px 9px\",\n          fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 600,\n          letterSpacing: \"0.2em\", textTransform: \"uppercase\",\n        }}>{a?.topic}</span>\n        <span style={{\n          fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 500,\n          letterSpacing: \"0.2em\", textTransform: \"uppercase\", color: \"var(--ink)\", opacity: 0.55,\n        }}>Top Pick в”¬в•– {a?.minutes} min</span>\n      </div>\n      <h2 style={{\n        margin: \"14px 0 10px\",\n        fontFamily: \"'Playfair Display', serif\",\n        fontSize: 38, lineHeight: 1.15, fontWeight: 500,\n        letterSpacing: \"-0.01em\", color: \"var(--ink)\",\n        textWrap: \"pretty\", maxWidth: 920,\n        textDecoration: hov ? \"underline\" : \"none\",\n        textDecorationThickness: \"1px\", textUnderlineOffset: \"6px\",\n      }}>{a?.headline}</h2>\n      <p style={{\n        margin: 0, maxWidth: 780,\n        fontFamily: \"'Inter', sans-serif\", fontSize: 15, lineHeight: 1.6,\n        color: \"var(--ink)\", opacity: 0.72,\n      }}>{a?.summary}</p>\n      <div style={{\n        marginTop: 14, display: \"flex\", gap: 14, alignItems: \"center\",\n        fontFamily: \"'Inter', sans-serif\", fontSize: 11,\n        color: \"var(--ink)\", opacity: 0.6,\n      }}>\n        <span>By {a?.author}</span>\n        <span>в”¬в•–</span>\n        <span>{a?.source}</span>\n        <span>в”¬в•–</span>\n        <span>{a?.minutes} min read</span>\n        <span style={{ marginLeft: \"auto\", opacity: 0.7 }}>О“ГҮГ¶ Read the full dispatch</span>\n      </div>\n    </article>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Section header О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsSection({ label, children, viewAll = true }) {\n  return (\n    <section style={{ marginTop: 56 }}>\n      <div style={{\n        display: \"flex\", justifyContent: \"space-between\", alignItems: \"baseline\",\n        paddingBottom: 14, borderBottom: \"1px solid var(--ink)\", marginBottom: 24,\n      }}>\n        <h3 style={{\n          margin: 0, fontFamily: \"'Inter', sans-serif\",\n          fontSize: 13, fontWeight: 700, letterSpacing: \"0.28em\",\n          textTransform: \"uppercase\", color: \"var(--ink)\",\n        }}>{label}</h3>\n        {viewAll && (\n          <a href=\"#\" style={{\n            fontFamily: \"'Inter', sans-serif\", fontSize: 11, fontWeight: 500,\n            letterSpacing: \"0.2em\", textTransform: \"uppercase\",\n            color: \"var(--ink)\", opacity: 0.65, textDecoration: \"none\",\n            display: \"inline-flex\", alignItems: \"center\", gap: 6,\n          }}>View All <span style={{ fontSize: 14 }}>О“ГҘГҶ</span></a>\n        )}\n      </div>\n      {children}\n    </section>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Story card (clean, no geometric shapes) О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsCard({ a, variant = \"compact\", match }) {\n  const [hov, setHov] = sUS(false);\n  const pct = match ?? Math.round((a?.score || 0) * 100);\n\n  if (variant === \"row\") {\n    return (\n      <article onMouseEnter={() => setHov(true)} onMouseLeave={() => setHov(false)}\n        style={{\n          display: \"grid\", gridTemplateColumns: \"1fr 140px\", gap: 16,\n          padding: \"14px 0\", borderBottom: \"1px solid rgba(0,0,0,0.1)\",\n          cursor: \"pointer\",\n        }}>\n        <div>\n          <div style={{ fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 500,\n            letterSpacing: \"0.2em\", color: \"var(--ink)\", opacity: 0.55, marginBottom: 6 }}>\n            {a?.author} в”¬в•– {a?.minutes} min\n          </div>\n          <h4 style={{\n            margin: \"0 0 8px\", fontFamily: \"'Playfair Display', serif\",\n            fontSize: 17, fontWeight: 500, lineHeight: 1.3, color: \"var(--ink)\",\n            textDecoration: hov ? \"underline\" : \"none\",\n            textDecorationThickness: \"1px\", textUnderlineOffset: \"4px\",\n          }}>{a?.headline}</h4>\n          <MatchChip pct={pct} compact/>\n        </div>\n        <NewsImg a={a} ratio=\"4 / 3\"/>\n      </article>\n    );\n  }\n\n  if (variant === \"large\") {\n    return (\n      <article onMouseEnter={() => setHov(true)} onMouseLeave={() => setHov(false)}\n        style={{ cursor: \"pointer\" }}>\n        <div style={{ overflow: \"hidden\", position: \"relative\" }}>\n          <div style={{\n            transform: hov ? \"scale(1.02)\" : \"scale(1)\",\n            transition: \"transform 500ms cubic-bezier(.2,.7,.2,1)\",\n          }}>\n            <NewsImg a={a} ratio=\"16 / 10\"/>\n          </div>\n          <div style={{ position: \"absolute\", top: 12, right: 12 }}>\n            <MatchChip pct={pct} compact/>\n          </div>\n        </div>\n        <div style={{ display: \"flex\", gap: 10, alignItems: \"center\",\n          marginTop: 14, fontFamily: \"'Inter', sans-serif\", fontSize: 10,\n          letterSpacing: \"0.18em\", color: \"var(--ink)\", opacity: 0.6, textTransform: \"uppercase\" }}>\n          <span>{a?.topic}</span>\n          <span>в”¬в•–</span>\n          <span>{a?.author}</span>\n        </div>\n        <h3 style={{\n          margin: \"8px 0 8px\", fontFamily: \"'Playfair Display', serif\",\n          fontSize: 22, fontWeight: 500, lineHeight: 1.25, color: \"var(--ink)\",\n          textDecoration: hov ? \"underline\" : \"none\",\n          textDecorationThickness: \"1px\", textUnderlineOffset: \"4px\",\n        }}>{a?.headline}</h3>\n        <p style={{\n          margin: \"0 0 10px\", fontFamily: \"'Inter', sans-serif\", fontSize: 13,\n          lineHeight: 1.55, color: \"var(--ink)\", opacity: 0.72,\n          display: \"-webkit-box\", WebkitLineClamp: 2, WebkitBoxOrient: \"vertical\", overflow: \"hidden\",\n        }}>{a?.summary}</p>\n      </article>\n    );\n  }\n\n  // compact\n  return (\n    <article onMouseEnter={() => setHov(true)} onMouseLeave={() => setHov(false)}\n      style={{ cursor: \"pointer\" }}>\n      <div style={{ overflow: \"hidden\", position: \"relative\" }}>\n        <div style={{\n          transform: hov ? \"scale(1.03)\" : \"scale(1)\",\n          transition: \"transform 450ms cubic-bezier(.2,.7,.2,1)\",\n        }}>\n          <NewsImg a={a} ratio=\"4 / 3\"/>\n        </div>\n        <div style={{ position: \"absolute\", top: 8, right: 8 }}>\n          <MatchChip pct={pct} compact/>\n        </div>\n      </div>\n      <h4 style={{\n        margin: \"12px 0 6px\", fontFamily: \"'Playfair Display', serif\",\n        fontSize: 16, fontWeight: 500, lineHeight: 1.3, color: \"var(--ink)\",\n        textDecoration: hov ? \"underline\" : \"none\",\n        textDecorationThickness: \"1px\", textUnderlineOffset: \"3px\",\n      }}>{a?.headline}</h4>\n      <div style={{ fontFamily: \"'Inter', sans-serif\", fontSize: 10, fontWeight: 500,\n        letterSpacing: \"0.18em\", color: \"var(--ink)\", opacity: 0.55, textTransform: \"uppercase\" }}>\n        {a?.author} в”¬в•– {a?.minutes} min\n      </div>\n    </article>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Podcast card (square image, player controls) О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsPodcastCard({ a, playing, onToggle, match }) {\n  const [hov, setHov] = sUS(false);\n  const pct = match ?? Math.round((a?.score || 0) * 100);\n  const isPlaying = playing === a?.id;\n  return (\n    <article onMouseEnter={() => setHov(true)} onMouseLeave={() => setHov(false)}\n      onClick={() => onToggle && onToggle(a?.id)}\n      style={{\n        display: \"grid\", gridTemplateColumns: \"96px minmax(0, 1fr)\", gap: 14,\n        padding: 14, border: \"1px solid rgba(0,0,0,0.12)\",\n        background: isPlaying ? \"var(--ink)\" : \"var(--bone)\",\n        color: isPlaying ? \"var(--bone)\" : \"var(--ink)\",\n        cursor: \"pointer\", transition: \"all 180ms\",\n      }}>\n      <div style={{ position: \"relative\" }}>\n        <NewsImg a={a} ratio=\"1 / 1\"/>\n        <div style={{\n          position: \"absolute\", inset: 0, display: \"flex\",\n          alignItems: \"center\", justifyContent: \"center\",\n        }}>\n          <div style={{\n            width: 36, height: 36, borderRadius: \"50%\",\n            background: isPlaying ? \"var(--accent)\" : \"var(--bone)\",\n            border: \"1px solid var(--ink)\",\n            display: \"flex\", alignItems: \"center\", justifyContent: \"center\",\n            transform: hov ? \"scale(1.08)\" : \"scale(1)\",\n            transition: \"transform 180ms\",\n          }}>\n            {isPlaying ? (\n              <svg width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"var(--bone)\">\n                <rect x=\"2\" y=\"1.5\" width=\"2\" height=\"7\"/><rect x=\"6\" y=\"1.5\" width=\"2\" height=\"7\"/>\n              </svg>\n            ) : (\n              <svg width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"var(--ink)\">\n                <path d=\"M2 1.5 L8.5 5 L2 8.5 Z\"/>\n              </svg>\n            )}\n          </div>\n        </div>\n      </div>\n      <div style={{ display: \"flex\", flexDirection: \"column\", gap: 6, minWidth: 0 }}>\n        <div style={{ fontFamily: \"'Inter', sans-serif\", fontSize: 9, fontWeight: 600,\n          letterSpacing: \"0.22em\", textTransform: \"uppercase\", opacity: 0.6 }}>\n          Podcast в”¬в•– {a?.topic}\n        </div>\n        <h4 style={{ margin: 0, fontFamily: \"'Playfair Display', serif\",\n          fontSize: 14, fontWeight: 500, lineHeight: 1.3,\n          display: \"-webkit-box\", WebkitLineClamp: 2, WebkitBoxOrient: \"vertical\", overflow: \"hidden\",\n        }}>{a?.headline}</h4>\n        <p style={{ margin: 0, fontFamily: \"'Inter', sans-serif\", fontSize: 11,\n          lineHeight: 1.5, opacity: 0.75,\n          display: \"-webkit-box\", WebkitLineClamp: 2, WebkitBoxOrient: \"vertical\", overflow: \"hidden\",\n        }}>{a?.summary}</p>\n        <div style={{ marginTop: \"auto\", display: \"flex\", justifyContent: \"space-between\",\n          alignItems: \"center\", gap: 8, paddingTop: 4, flexWrap: \"wrap\" }}>\n          <span style={{ fontFamily: \"'Inter', sans-serif\", fontSize: 9,\n            letterSpacing: \"0.12em\", opacity: 0.7, whiteSpace: \"nowrap\" }}>\n            {a?.minutes + 12} MIN в”¬в•– {a?.author}\n          </span>\n          <MatchChip pct={pct} compact/>\n        </div>\n      </div>\n    </article>\n  );\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Footer О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport function NewsFooter({ brand }) {\n  const socials = [\"IG\", \"вүЎВҘГІГ…\", \"TT\", \"YT\", \"RSS\"];\n  return (\n    <footer style={{ marginTop: 80, borderTop: \"3px solid var(--ink)\", paddingTop: 28 }}>\n      <div style={{ textAlign: \"center\", padding: \"8px 0 18px\" }}>\n        <h2 style={{\n          fontFamily: \"'Playfair Display', serif\", fontStyle: \"italic\",\n          fontSize: 32, margin: 0, fontWeight: 500, color: \"var(--ink)\",\n          letterSpacing: \"-0.01em\",\n        }}>\n          {brand}<span style={{ fontStyle: \"normal\", color: \"var(--accent)\" }}>*</span>\n        </h2>\n      </div>\n      <div style={{\n        borderTop: \"1px solid var(--ink)\", padding: \"16px 0\",\n        display: \"flex\", justifyContent: \"space-between\", alignItems: \"center\",\n        fontFamily: \"'Inter', sans-serif\", fontSize: 11,\n      }}>\n        <span style={{ color: \"var(--ink)\", opacity: 0.7 }}>\n          Copyright в”¬вҢҗ 2026 в”¬в•– {brand} в”¬в•– All rights reserved\n        </span>\n        <div style={{ display: \"flex\", gap: 8 }}>\n          {socials.map(s => (\n            <a key={s} href=\"#\" style={{\n              width: 26, height: 26, border: \"1px solid var(--ink)\",\n              display: \"inline-flex\", alignItems: \"center\", justifyContent: \"center\",\n              fontFamily: \"'JetBrains Mono', monospace\", fontSize: 9,\n              color: \"var(--ink)\", textDecoration: \"none\",\n            }}>{s}</a>\n          ))}\n        </div>\n      </div>\n    </footer>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"E:\\news\\tailwind.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\news\\test-render.js","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'html' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":6,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":13,"suggestions":[{"messageId":"removeVar","data":{"varName":"html"},"fix":{"range":[120,157],"text":""},"desc":"Remove unused variable 'html'."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport { renderToString } from 'react-dom/server';\nimport App from './src/App.jsx';\n\ntry {\n  const html = renderToString(<App />);\n  console.log(\"No rendering error!\");\n} catch (err) 